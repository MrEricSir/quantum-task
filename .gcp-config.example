# GCP deployment configuration
# Copy this file to .gcp-config and fill in your values.
# .gcp-config is gitignored — never commit it.

# GCP project ID (find it in the GCP Console or `gcloud projects list`)
GCP_PROJECT_ID="your-project-id"

# Region for Cloud Run and Artifact Registry
GCP_REGION="us-central1"

# Cloud Run service name
GCP_SERVICE_NAME="todo-backend"

# Artifact Registry repository name
GCP_AR_REPO="todo"

# ── LLM provider ─────────────────────────────────────────────────────────────
# Uncomment one block. The app uses the OpenAI-compatible API format.

# Option 1: Google Gemini (pay-as-you-go, very cheap for personal use)
#   Get a key at https://aistudio.google.com
LLM_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
LLM_API_KEY="your-gemini-api-key"
LLM_MODEL="gemini-2.0-flash"

# Option 2: Groq (free tier available)
#   Get a key at https://console.groq.com
# LLM_BASE_URL="https://api.groq.com/openai/v1"
# LLM_API_KEY="your-groq-api-key"
# LLM_MODEL="llama-3.1-8b-instant"

# Option 3: Ollama (local dev only — not suitable for Cloud Run)
# LLM_BASE_URL="http://localhost:11434/v1"
# LLM_API_KEY="ollama"
# LLM_MODEL="llama3.2"

# Password for the single-user login gate (leave empty to disable auth)
AUTH_PASSWORD="your-password"

# ── Optional features ─────────────────────────────────────────────────────────
# These are injected at deploy time via GitHub secrets, not baked in here.
# If you run `./dev.sh gcp-update-env` and want to preserve them on the running
# service, export them in your shell first:
#
#   export TAVILY_API_KEY="tvly-..."   # Workshop web search (free at tavily.com)
#   ./dev.sh gcp-update-env

