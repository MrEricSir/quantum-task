# Copy this file to .env and fill in the values you want to override.
# All variables are optional — defaults are set for local development with Ollama.

# ── Database ──────────────────────────────────────────────────────────────────
# Default: SQLite at ./todos.db (relative to the backend directory)
# For PostgreSQL: postgresql+psycopg2://user:pass@host/dbname
# For Cloud SQL (Cloud Run): postgresql+psycopg2://user:pass@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE
# For Cloud Storage-backed SQLite (Cloud Run): sqlite:////app/data/todos.db
# DATABASE_URL=sqlite:///./todos.db

# ── LLM (AI Quick Add + Daily Briefing) ──────────────────────────────────────
# Default: Ollama running locally
# For Gemini: set all three variables below
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_API_KEY=your-gemini-api-key
# LLM_MODEL=gemini-2.0-flash

# ── CORS ──────────────────────────────────────────────────────────────────────
# Default: http://localhost:5173
# In production, set this to your Firebase Hosting URL
# ALLOWED_ORIGIN=https://your-project.web.app

# ── Workshop web search (optional) ───────────────────────────────────────────
# Get a free API key at https://tavily.com
# Without this, the "+ Search web" button in the Workshop will return a 503 error.
# TAVILY_API_KEY=

# ── Withings Public API ───────────--------────────────────────────────────────
# WITHINGS_CLIENT_ID=
# WITHINGS_SECRET=
